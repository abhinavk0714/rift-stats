# Copy to .env. Use either DATABASE_URL or the DB_* vars below.
# If your password has # or @, use DB_* (paste password as-is; no encoding).
#
# Option A — single URL (password must not contain # or @, or encode: # -> %23, @ -> %40)
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Option B — separate vars (recommended if password has special chars)
# DB_HOST=aws-0-us-west-2.pooler.supabase.com
# DB_USER=postgres.[PROJECT-REF]
# DB_PASSWORD=your-password-as-is
# DB_NAME=postgres
# DB_PORT=6543
#
# API (optional; defaults used by uvicorn/Docker)
# API_HOST=0.0.0.0
# API_PORT=8000
